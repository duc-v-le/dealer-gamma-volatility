# Environment configuration for the dealer-gamma replication pipeline.
# Copy this file to ".env", set your own value, and export it in your shell
# (for example:  export WRDS_USER=your_username ). The real .env is gitignored —
# never commit credentials.
#
# WRDS username. The WRDS *password* is read separately from ~/.pgpass (recommended)
# and is therefore not stored here. See the README "Data availability" section.
WRDS_USER=your_wrds_username
